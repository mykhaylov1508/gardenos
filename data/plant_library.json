-- ============================================
-- GardenOS v2.0 - Схема бази даних
-- ============================================

-- Вмикаємо UUID-генератор
create extension if not exists "uuid-ossp";

-- ============================================
-- ТАБЛИЦЯ 1: Бібліотека рослин (PlantLibrary)
-- Це база знань, яка вже заповнена
-- ============================================
create table plant_library (
  id uuid primary key default uuid_generate_v4(),
  name_uk text not null,
  name_latin text,
  category text not null, -- vegetable / fruit / herb / tree / bush / flower
  family text,
  icon_slug text,
  frost_tolerance_c numeric,
  optimal_temp_min numeric,
  optimal_temp_max numeric,
  heat_stress_temp numeric,
  vegetation_days int not null,
  full_maturity_days int,
  watering_interval_days int not null,
  watering_liters_per_m2 numeric,
  soil_moisture_preference text,
  feeding_interval_days int,
  feeding_type text,
  feeder_type text,
  good_companions text[],
  bad_companions text[],
  common_diseases jsonb,
  nutrient_deficiencies jsonb,
  care_tips text[],
  harvest_signs text,
  regional_notes jsonb,
  created_at timestamp default now()
);

-- ============================================
-- ТАБЛИЦЯ 2: Користувачі (розширення auth.users)
-- ============================================
create table profiles (
  id uuid references auth.users primary key,
  email text,
  full_name text,
  region text,
  garden_type text,
  created_at timestamp default now()
);

-- Автоматично створювати профіль при реєстрації
create or replace function public.handle_new_user()
returns trigger as $$
begin
  insert into public.profiles (id, email)
  values (new.id, new.email);
  return new;
end;
$$ language plpgsql security definer;

create trigger on_auth_user_created
  after insert on auth.users
  for each row execute procedure public.handle_new_user();

-- ============================================
-- ТАБЛИЦЯ 3: Зони на городі (грядки)
-- ============================================
create table my_zones (
  id uuid primary key default uuid_generate_v4(),
  user_id uuid references profiles(id) on delete cascade,
  name text not null,
  zone_type text, -- bed / greenhouse / pot / tree_circle
  notes text,
  created_at timestamp default now()
);

-- ============================================
-- ТАБЛИЦЯ 4: Мої рослини (інстанси на городі)
-- ============================================
create table my_plants (
  id uuid primary key default uuid_generate_v4(),
  user_id uuid references profiles(id) on delete cascade,
  zone_id uuid references my_zones(id),
  library_id uuid references plant_library(id),
  custom_name text,
  planted_date date,
  expected_harvest_date date,
  area_m2 numeric default 1,
  status text default 'active', -- active / harvested / dead
  notes text,
  created_at timestamp default now()
);

-- ============================================
-- ТАБЛИЦЯ 5: Лог подій (що я зробив)
-- ============================================
create table events_log (
  id uuid primary key default uuid_generate_v4(),
  user_id uuid references profiles(id) on delete cascade,
  plant_id uuid references my_plants(id) on delete cascade,
  event_type text not null, -- water / feed / harvest / observe / prune
  event_date date not null default current_date,
  quantity numeric,
  unit text,
  notes text,
  photo_url text,
  created_at timestamp default now()
);

-- ============================================
-- ТАБЛИЦЯ 6: Задачі (що мені каже система зробити)
-- ============================================
create table tasks (
  id uuid primary key default uuid_generate_v4(),
  user_id uuid references profiles(id) on delete cascade,
  plant_id uuid references my_plants(id) on delete cascade,
  task_type text not null, -- water / feed / harvest / alert
  title text not null,
  action_description text,
  explanation_text text,
  due_date date not null default current_date,
  recommended_time text,
  priority text default 'normal', -- urgent / high / normal / low
  is_completed boolean default false,
  completed_at timestamp,
  created_at timestamp default now()
);

-- ============================================
-- ТАБЛИЦЯ 7: Алерти (погодні та критичні)
-- ============================================
create table alerts (
  id uuid primary key default uuid_generate_v4(),
  user_id uuid references profiles(id) on delete cascade,
  plant_id uuid references my_plants(id) on delete cascade,
  alert_type text not null, -- frost / heat / disease / pest
  severity text not null, -- critical / warning / info
  title text not null,
  actions jsonb,
  explanation_text text,
  deadline timestamp,
  is_acknowledged boolean default false,
  created_at timestamp default now()
);

-- ============================================
-- ІНДЕКСИ для швидкості
-- ============================================
create index idx_my_plants_user on my_plants(user_id);
create index idx_events_log_plant on events_log(plant_id);
create index idx_tasks_user_date on tasks(user_id, due_date);
create index idx_alerts_user on alerts(user_id, created_at);

-- ============================================
-- RLS (Row Level Security) — кожен бачить тільки своє
-- ============================================
alter table profiles enable row level security;
alter table my_zones enable row level security;
alter table my_plants enable row level security;
alter table events_log enable row level security;
alter table tasks enable row level security;
alter table alerts enable row level security;

-- Політики: користувач бачить тільки свої дані
create policy "Users can view own profile" on profiles for select using (auth.uid() = id);
create policy "Users can update own profile" on profiles for update using (auth.uid() = id);

create policy "Users can view own zones" on my_zones for select using (auth.uid() = user_id);
create policy "Users can insert own zones" on my_zones for insert with check (auth.uid() = user_id);
create policy "Users can update own zones" on my_zones for update using (auth.uid() = user_id);
create policy "Users can delete own zones" on my_zones for delete using (auth.uid() = user_id);

create policy "Users can view own plants" on my_plants for select using (auth.uid() = user_id);
create policy "Users can insert own plants" on my_plants for insert with check (auth.uid() = user_id);
create policy "Users can update own plants" on my_plants for update using (auth.uid() = user_id);
create policy "Users can delete own plants" on my_plants for delete using (auth.uid() = user_id);

create policy "Users can view own events" on events_log for select using (auth.uid() = user_id);
create policy "Users can insert own events" on events_log for insert with check (auth.uid() = user_id);
create policy "Users can update own events" on events_log for update using (auth.uid() = user_id);
create policy "Users can delete own events" on events_log for delete using (auth.uid() = user_id);

create policy "Users can view own tasks" on tasks for select using (auth.uid() = user_id);
create policy "Users can insert own tasks" on tasks for insert with check (auth.uid() = user_id);
create policy "Users can update own tasks" on tasks for update using (auth.uid() = user_id);
create policy "Users can delete own tasks" on tasks for delete using (auth.uid() = user_id);

create policy "Users can view own alerts" on alerts for select using (auth.uid() = user_id);
create policy "Users can insert own alerts" on alerts for insert with check (auth.uid() = user_id);
create policy "Users can update own alerts" on alerts for update using (auth.uid() = user_id);
create policy "Users can delete own alerts" on alerts for delete using (auth.uid() = user_id);

-- Бібліотека рослин доступна всім для читання
create policy "Anyone can read plant library" on plant_library for select using (true);

